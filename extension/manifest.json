{
  "manifest_version": 3,
  "name": "Campus SSO Helper",
  "short_name": "Campus SSO",
  "description": "大学のMicrosoft SSOに資格情報を自動入力する非公式のSafari機能拡張です。",
  "version": "1.2.1",
  "permissions": ["storage"],
  "host_permissions": [
    "https://wsdmoodle.waseda.jp/*",
    "https://login.microsoftonline.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://wsdmoodle.waseda.jp/*"],
      "js": ["core.js", "moodle.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://login.microsoftonline.com/*"],
      "js": ["core.js", "microsoft.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "Campus SSO Helper",
    "default_popup": "popup/popup.html"
  },
  "icons": {
    "128": "icons/icon.svg",
    "512": "icons/icon.svg"
  },
  "browser_specific_settings": {
    "safari": {
      "strict_min_version": "15.4"
    }
  }
}
